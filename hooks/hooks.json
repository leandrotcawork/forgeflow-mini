{
  "hooks": {
    "SessionStart": [
      {
        "name": "brain-session-start",
        "command": "bash hooks/session-start.sh",
        "description": "Inject ForgeFlow Active orientation into session context"
      }
    ],
    "SubagentStart": [
      {
        "name": "brain-subagent-start",
        "command": "bash hooks/subagent-start.sh",
        "description": "Inject discipline contract into every spawned subagent"
      }
    ],
    "PreToolUse": [
      {
        "name": "hippocampus-guard",
        "command": "bash hooks/hippocampus-guard.sh",
        "toolNames": ["Write", "Edit"],
        "description": "Block writes to .brain/hippocampus/"
      },
      {
        "name": "workflow-pre-tool-use",
        "command": "bash hooks/pre-tool-use.sh",
        "toolNames": ["Write", "Edit"],
        "description": "Enforce workflow-state write gates"
      }
    ],
    "Stop": [
      {
        "name": "workflow-stop",
        "command": "bash hooks/stop.sh",
        "description": "Prevent finalization before verification passes"
      }
    ]
  }
}
